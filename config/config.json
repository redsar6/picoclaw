{
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": false,
      "model_name": "groq-llama",
      "max_tokens": 2048,
      "context_window": 32768,
      "temperature": 0.3,
      "max_tool_iterations": 10,
      "summarize_message_threshold": 20,
      "summarize_token_percent": 75,
      "split_on_marker": false,
      "tool_feedback": {
        "enabled": false,
        "max_args_length": 300
      }
    }
  },
  "model_list": [
    {
      "model_name": "groq-llama",
      "model": "groq/llama-3.3-70b-versatile",
      "api_key": "GROQ_API_KEY_AQUI",
      "api_base": "https://api.groq.com/openai/v1"
    },
    {
      "model_name": "claude-haiku",
      "model": "anthropic/claude-haiku-4-5-20251001",
      "api_key": "ANTHROPIC_API_KEY_AQUI",
      "api_base": "https://api.anthropic.com/v1"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "TELEGRAM_BOT_TOKEN_AQUI",
      "allow_from": [],
      "use_markdown_v2": false,
      "streaming": {
        "enabled": true
      }
    }
  },
  "tools": {
    "allow_read_paths": null,
    "allow_write_paths": null,
    "web": {
      "enabled": true,
      "prefer_native": true,
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    },
    "cron": {
      "enabled": true,
      "exec_timeout_minutes": 5
    },
    "mcp": {
      "enabled": true,
      "discovery": {
        "enabled": true,
        "ttl": 5,
        "max_search_results": 5,
        "use_bm25": true,
        "use_regex": false
      },
      "servers": {
        "google-sheets": {
          "enabled": true,
          "type": "http",
          "url": "https://sheets.mcp.claude.com/mcp",
          "headers": {
            "Authorization": "Bearer GOOGLE_SERVICE_ACCOUNT_KEY_AQUI"
          }
        }
      }
    },
    "exec": {
      "enabled": false
    },
    "skills": {
      "enabled": true
    },
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "spawn": {
      "enabled": true
    },
    "subagent": {
      "enabled": true
    },
    "web_fetch": {
      "enabled": true
    },
    "message": {
      "enabled": true
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "hot_reload": false,
    "log_level": "info"
  }
}
